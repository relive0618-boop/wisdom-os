{
  "name": "wisdom-os",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter web test:e2e",
    "typecheck": "pnpm -r typecheck",
    "preinstall": "npx only-allow pnpm",
    "seed:supabase": "pnpm --filter web seed:supabase",
    "seed:supabase:apply": "pnpm --filter web seed:supabase:apply",
    "verify:preview": "pnpm --filter web exec tsx ../../scripts/verify-preview.mts"
  },
  "engines": {
    "node": ">=20"
  }
}
